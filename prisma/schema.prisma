generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  TESTING
  DONE
  BLOCKED
  CANCELLED
}

enum ScheduleType {
  MEETING
  TASK_DEADLINE
  MILESTONE
  REMINDER
  PERSONAL
  HOLIDAY
}

enum FileType {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  ARCHIVE
  CODE
  OTHER
}

enum MessageType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_COMMENTED
  TASK_COMPLETED
  MEMBER_INVITED
  MEMBER_JOINED
  SCHEDULE_REMINDER
  MILESTONE_REMINDER
  FILE_UPLOADED
  PROJECT_UPDATED
  SYSTEM
  MENTION
}

enum OperationType {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
  COMMENT
  UPLOAD
  DOWNLOAD
  INVITE
  REMOVE
  PERMISSION_CHANGE
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  username        String        @unique
  passwordHash    String
  fullName        String?
  avatar          String?
  phone           String?
  status          UserStatus    @default(ACTIVE)
  lastLoginAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  projects              ProjectMember[]
  ownedProjects         Project[]           @relation("ProjectOwner")
  assignedTasks         Task[]              @relation("TaskAssignee")
  createdTasks          Task[]              @relation("TaskCreator")
  comments              TaskComment[]
  statusHistoryChanges  TaskStatusHistory[]
  schedules             Schedule[]
  files                 File[]
  messages              Message[]           @relation("MessageReceiver")
  sentMessages          Message[]           @relation("MessageSender")
  operationLogs         OperationLog[]
  invitedMembers        ProjectMember[]     @relation("MemberInviter")

  @@index([email])
  @@index([username])
  @@index([status])
}

model Project {
  id              String        @id @default(uuid())
  name            String
  description     String?
  key             String        @unique
  status          ProjectStatus @default(PLANNING)
  color           String?
  icon            String?
  startDate       DateTime?
  endDate         DateTime?
  ownerId         String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  owner               User                  @relation("ProjectOwner", fields: [ownerId], references: [id])
  members             ProjectMember[]
  roles               ProjectRole[]
  tasks               Task[]
  milestones          Milestone[]
  schedules           Schedule[]
  files               File[]
  operationLogs       OperationLog[]
  milestoneReminders  MilestoneReminder[]

  @@index([ownerId])
  @@index([status])
  @@index([createdAt])
}

model ProjectMember {
  id              String        @id @default(uuid())
  projectId       String
  userId          String
  roleId          String?
  joinedAt        DateTime      @default(now())
  invitedBy       String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            ProjectRole?  @relation(fields: [roleId], references: [id])
  invitedByUser   User?         @relation("MemberInviter", fields: [invitedBy], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([invitedBy])
}

model ProjectRole {
  id              String        @id @default(uuid())
  projectId       String
  name            String
  description     String?
  isSystem        Boolean       @default(false)
  permissions     Json          @default("[]")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members         ProjectMember[]

  @@unique([projectId, name])
  @@index([projectId])
}

model Task {
  id              String        @id @default(uuid())
  projectId       String
  parentId        String?
  title           String
  description     String?
  priority        TaskPriority  @default(MEDIUM)
  status          TaskStatus    @default(TODO)
  assigneeId      String?
  creatorId       String
  milestoneId     String?
  startDate       DateTime?
  dueDate         DateTime?
  completedAt     DateTime?
  estimatedHours  Float?
  actualHours     Float?        @default(0)
  position        Int           @default(0)
  tags            String[]      @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent          Task?         @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks        Task[]        @relation("TaskSubtasks")
  assignee        User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator         User          @relation("TaskCreator", fields: [creatorId], references: [id])
  milestone       Milestone?    @relation(fields: [milestoneId], references: [id])
  comments        TaskComment[]
  statusHistories TaskStatusHistory[]
  attachments     File[]
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([dueDate])
  @@index([parentId])
}

model TaskStatusHistory {
  id              String        @id @default(uuid())
  taskId          String
  oldStatus       TaskStatus
  newStatus       TaskStatus
  changedById     String
  remark          String?
  createdAt       DateTime      @default(now())

  task            Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy       User          @relation(fields: [changedById], references: [id])

  @@index([taskId])
  @@index([changedById])
  @@index([createdAt])
}

model TaskComment {
  id              String        @id @default(uuid())
  taskId          String
  userId          String
  content         String
  mentions        String[]      @default([])
  attachments     String[]      @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  task            Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

model Milestone {
  id              String                @id @default(uuid())
  projectId       String
  name            String
  description     String?
  targetDate      DateTime
  achievedAt      DateTime?
  remindDays      Int[]                 @default([7, 3, 1])
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?

  project         Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks           Task[]
  reminders       MilestoneReminder[]

  @@index([projectId])
  @@index([targetDate])
}

model MilestoneReminder {
  id              String        @id @default(uuid())
  milestoneId     String
  projectId       String
  remindDay       Int
  sentAt          DateTime      @default(now())
  sentTo          String[]      @default([])

  milestone       Milestone     @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([milestoneId, remindDay])
  @@index([milestoneId])
  @@index([projectId])
  @@index([sentAt])
}

model Schedule {
  id              String        @id @default(uuid())
  projectId       String?
  userId          String
  title           String
  description     String?
  type            ScheduleType  @default(MEETING)
  startTime       DateTime
  endTime         DateTime
  isAllDay        Boolean       @default(false)
  location        String?
  meetingLink     String?
  repeatRule      String?
  remindMinutes   Int[]         @default([15])
  attendees       String[]      @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  project         Project?      @relation(fields: [projectId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([projectId])
  @@index([startTime, endTime])
  @@index([type])
}

model File {
  id              String        @id @default(uuid())
  projectId       String?
  taskId          String?
  userId          String
  name            String
  originalName    String
  path            String
  size            BigInt
  type            FileType      @default(OTHER)
  mimeType        String?
  hash            String?
  keywords        String[]      @default([])
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  project         Project?      @relation(fields: [projectId], references: [id])
  task            Task?         @relation(fields: [taskId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([taskId])
  @@index([userId])
  @@index([type])
  @@index([name])
}

model Message {
  id              String        @id @default(uuid())
  receiverId      String
  senderId        String?
  type            MessageType
  title           String
  content         String?
  relatedId       String?
  relatedType     String?
  isRead          Boolean       @default(false)
  readAt          DateTime?
  createdAt       DateTime      @default(now())

  receiver        User          @relation("MessageReceiver", fields: [receiverId], references: [id])
  sender          User?         @relation("MessageSender", fields: [senderId], references: [id])

  @@index([receiverId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}

model OperationLog {
  id              String        @id @default(uuid())
  projectId       String?
  userId          String
  type            OperationType
  entityType      String
  entityId        String
  title           String
  detail          Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())

  project         Project?      @relation(fields: [projectId], references: [id])
  user            User          @relation(fields: [userId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([type])
  @@index([createdAt])
}
